{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/root/.openclaw/workspace/.claude/hooks/auto-format.sh \"$CLAUDE_FILE_PATH\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/root/.openclaw/workspace/.claude/hooks/secret-check.sh \"$CLAUDE_FILE_PATH\""
          }
        ]
      }
    ]
  }
}
