# ETF 자동매매 시스템 환경변수 설정 예시
# 이 파일을 .env로 복사하고 실제 값을 입력하세요

# ====================================
# 한국투자증권 OpenAPI 설정
# ====================================
# API 포털에서 발급받은 키를 입력하세요
# https://apiportal.koreainvestment.com

# 앱 키 (32자리)
KIS_APP_KEY=your_app_key_here

# 앱 시크릿 (32자리)  
KIS_APP_SECRET=your_app_secret_here

# 계좌번호 (하이픈 없이)
KIS_ACCOUNT_NO=12345678901

# ====================================
# 데이터베이스 설정
# ====================================
# Oracle 데이터베이스 연결 정보

DB_HOST=oracle19c01
DB_PORT=1521
DB_SERVICE=PROD
DB_USER=stock
DB_PASSWORD=stock123

# ====================================
# 보안 설정  
# ====================================
# 데이터 암호화에 사용할 키 (32바이트 권장)
ENCRYPTION_KEY=your_32_byte_encryption_key_here

# JWT 토큰 시크릿 (웹 API 사용시)
JWT_SECRET=your_jwt_secret_key_here

# ====================================
# 알림 설정 (필수)
# ====================================
# 디스코드 웹훅 URL (메인 알림 시스템)
# 설정 방법: 디스코드 서버 → 채널 설정 → 연동 → 웹후크 → 새 웹후크 생성 → URL 복사
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# 디스코드 웹훅 생성 가이드:
# 1. 디스코드에서 #etf-signals 채널 생성
# 2. 채널 우클릭 → 채널 편집 → 연동 → 웹후크
# 3. "새 웹후크" 클릭 → 이름: "루나 ETF Bot"
# 4. "웹후크 URL 복사" → 위 DISCORD_WEBHOOK_URL에 붙여넣기

# 이메일 설정 (SMTP)
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_TO=recipient@example.com

# ====================================
# 외부 서비스 (선택사항)
# ====================================
# Redis 캐시 서버
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 웹 서버 설정
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_SECRET_KEY=your_web_secret_key

# ====================================
# 로깅 및 모니터링
# ====================================
# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 로그 파일 최대 크기 (MB)
LOG_MAX_SIZE=100

# ====================================
# 개발/테스트 설정
# ====================================
# 환경 모드 (development, production, test)
ENVIRONMENT=development

# 시뮬레이션 모드 (true/false)
SIMULATION_MODE=true

# API 딜레이 (초)
API_DELAY=0.5

# ====================================
# 성능 설정
# ====================================
# 워커 프로세스 수
WORKER_PROCESSES=4

# 배치 처리 크기
BATCH_SIZE=100

# 캐시 TTL (분)
CACHE_TTL=5

# ====================================
# 백업 설정
# ====================================
# 백업 디렉토리
BACKUP_DIR=/backup/etf_system

# 백업 보관 기간 (일)
BACKUP_RETENTION_DAYS=30

# 자동 백업 활성화 (true/false)
AUTO_BACKUP_ENABLED=true